#!/bin/bash

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)

# Auto-detect CLAUDE_BOX_PROFILE by walking up from PWD, same as git finds .git
if [ -z "$CLAUDE_BOX_PROFILE" ]; then
  _dir="$PWD"
  while [ "$_dir" != "/" ]; do
    if [ -f "$_dir/.claude/box-profile" ]; then
      CLAUDE_BOX_PROFILE=$(tr -d '[:space:]' < "$_dir/.claude/box-profile")
      break
    fi
    _dir=$(dirname "$_dir")
  done
  unset _dir
fi

# Resolve profile-aware paths (CLAUDE_BOX_PROFILE is optional; empty = default ~/.claude)
CLAUDE_DIR="${HOME}/.claude${CLAUDE_BOX_PROFILE:+-${CLAUDE_BOX_PROFILE}}"
#CLAUDE_JSON="${HOME}/.claude${CLAUDE_BOX_PROFILE:+-${CLAUDE_BOX_PROFILE}}.json"

# Ensure profile dir and auth file exist before mounting
mkdir -p "${CLAUDE_DIR}"
#touch "${CLAUDE_JSON}"

# IDE integrations are machine-level — share ide/ and ide-backups/ across all profiles via bind mount
mkdir -p "${HOME}/.claude/ide" "${HOME}/.claude/ide-backups"

if [ -n "$CLAUDE_BOX_PROFILE" ]; then
  echo "[claude] Profile: ${CLAUDE_BOX_PROFILE} (${CLAUDE_DIR})"
else
  echo "[claude] No profile detected, using default (${CLAUDE_DIR})"
fi

# Write only alive IDE ports (verify each port is actually listening)
# Use a temp file + mv for atomic update to avoid race with the container's lock file guardian
ALIVE_PORTS_TMP=$(mktemp "${CLAUDE_DIR}/.alive_ports.XXXXXX")
for lockfile in "${HOME}/.claude/ide"/*.lock; do
  [ -f "$lockfile" ] || continue
  port=$(basename "$lockfile" .lock)
  if nc -z localhost "$port" 2>/dev/null; then
    echo "$port" >> "$ALIVE_PORTS_TMP"
  fi
done
mv "$ALIVE_PORTS_TMP" "${CLAUDE_DIR}/.alive_ports"
echo "[claude] Alive IDE ports written: $(tr '\n' ' ' < "${CLAUDE_DIR}/.alive_ports")"

COMPOSE_RUN_OPTS=()

# Parse box-level flags before passing remaining args to Claude
BOX_ARGS=()
PASSTHROUGH_ARGS=()
LIVE_LOG_FILE="${CLAUDE_BOX_LIVE_LOG:-}"
_next_is_live_log=0
for arg in "$@"; do
  if [ "$_next_is_live_log" = "1" ]; then
    LIVE_LOG_FILE="$arg"
    _next_is_live_log=0
    continue
  fi
  case "$arg" in
    --rebuild)   COMPOSE_RUN_OPTS+=(--build) ;;
    --live-log)  _next_is_live_log=1 ;;
    *)           PASSTHROUGH_ARGS+=("$arg") ;;
  esac
done
unset _next_is_live_log

if [ "$_next_is_live_log" = "1" ]; then
  echo "[claude] ERROR: --live-log requires a file path" >&2
  exit 1
fi

EXTRA_MOUNTS=()

# Detect git worktree: .git is a file, not a directory
if [ -f "${PWD}/.git" ]; then
  # Extract main repo path from .git file
  # e.g. "gitdir: /path/to/main/.git/worktrees/branch"
  GITDIR=$(cat "${PWD}/.git" | grep gitdir | sed 's/^gitdir: //')
  MAIN_REPO=$(echo "$GITDIR" | sed 's|/.git/worktrees/.*||')

  if [ -d "${MAIN_REPO}/.git" ]; then
    echo "[claude] Worktree detected. Mounting main repo .git: ${MAIN_REPO}/.git"
    EXTRA_MOUNTS+=(-v "${MAIN_REPO}/.git:${MAIN_REPO}/.git")
  fi
fi

LIVE_LOG_PROMPT=()
if [ -n "$LIVE_LOG_FILE" ]; then
  echo "[claude] Live log: ${LIVE_LOG_FILE}"
  LIVE_LOG_PROMPT=("After each of your responses this session, append the exchange to ${LIVE_LOG_FILE} as clean markdown — user message under '### You', your response under '### Claude', separated by ---. Create the file if it doesn't exist.")
fi

CLAUDE_DIR="$CLAUDE_DIR" CLAUDE_JSON="$CLAUDE_JSON" \
docker compose -f "$SCRIPT_DIR/../docker-compose.yml" run --rm \
  "${COMPOSE_RUN_OPTS[@]}" \
  -v "${PWD}:${PWD}" \
  -w "${PWD}" \
  -v "${HOME}/.claude/ide:/home/claudeuser/.claude/ide" \
  -v "${HOME}/.claude/ide-backups:/home/claudeuser/.claude/ide-backups" \
  "${EXTRA_MOUNTS[@]}" \
  claude "${LIVE_LOG_PROMPT[@]}" "${PASSTHROUGH_ARGS[@]}"