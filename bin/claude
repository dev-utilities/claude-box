#!/bin/bash

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)

# Write only alive IDE ports (verify each port is actually listening)
# Use a temp file + mv for atomic update to avoid race with the container's lock file guardian
ALIVE_PORTS_TMP=$(mktemp ~/.claude/.alive_ports.XXXXXX)
for lockfile in ~/.claude/ide/*.lock; do
  [ -f "$lockfile" ] || continue
  port=$(basename "$lockfile" .lock)
  if nc -z localhost "$port" 2>/dev/null; then
    echo "$port" >> "$ALIVE_PORTS_TMP"
  fi
done
mv "$ALIVE_PORTS_TMP" ~/.claude/.alive_ports
echo "[claude] Alive IDE ports written: $(tr '\n' ' ' < ~/.claude/.alive_ports)"

EXTRA_MOUNTS=()

# Detect git worktree: .git is a file, not a directory
if [ -f "${PWD}/.git" ]; then
  # Extract main repo path from .git file
  # e.g. "gitdir: /path/to/main/.git/worktrees/branch"
  GITDIR=$(cat "${PWD}/.git" | grep gitdir | sed 's/^gitdir: //')
  MAIN_REPO=$(echo "$GITDIR" | sed 's|/.git/worktrees/.*||')

  if [ -d "${MAIN_REPO}/.git" ]; then
    echo "[claude] Worktree detected. Mounting main repo .git: ${MAIN_REPO}/.git"
    EXTRA_MOUNTS+=(-v "${MAIN_REPO}/.git:${MAIN_REPO}/.git")
  fi
fi

docker compose -f "$SCRIPT_DIR/../docker-compose.yml" run --rm \
  -v "${PWD}:${PWD}" \
  -w "${PWD}" \
  "${EXTRA_MOUNTS[@]}" \
  claude "$@"