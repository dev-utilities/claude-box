# Codex CLI on the shared box-base (Ubuntu 24.04 + node/nvm + uv + sudo).
# box-base is built automatically by the launcher before this image.
FROM box-base:latest

ENV CODEX_HOME=/home/boxuser/.codex
ENV PATH="${CODEX_HOME}/bin:${PATH}"

RUN mkdir -p "$CODEX_HOME" \
    && npm install -g @openai/codex \
    && codex --version

ENTRYPOINT ["codex"]
