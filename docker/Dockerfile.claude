# Claude Code on the shared box-base (Ubuntu 24.04 + node/nvm + uv + sudo).
# box-base is built automatically by the launcher before this image.
FROM box-base:latest

# Install Claude Code as boxuser so it lands in ~/.local/bin (already on PATH)
RUN curl -fsSL https://claude.ai/install.sh | bash

COPY entrypoint.py /home/boxuser/entrypoint.py
# Managed-policy memory: loaded in every session, invisible to host-side
# Claude instances sharing the same CLAUDE_CONFIG_DIR.
COPY box-claude.md /etc/claude-code/CLAUDE.md

ENTRYPOINT ["python3", "/home/boxuser/entrypoint.py"]
